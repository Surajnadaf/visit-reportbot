from telegram import Update, InputFile
from telegram.ext import Application, CommandHandler, ContextTypes
from docx import Document

TOKEN = "PASTE_YOUR_BOT_TOKEN_HERE"

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "Welcome to Visit Report Bot!\n\nSend /visit to create a report."
    )

async def visit(update: Update, context: ContextTypes.DEFAULT_TYPE):
    doc = Document()

    doc.add_heading('Visit Report', level=1)
    doc.add_paragraph('Project Name: GEBE')
    doc.add_paragraph('Location: Raichur')
    doc.add_paragraph('Visit Date: 19 June 2026')
    doc.add_paragraph('Objective of Visit: Monitoring Visit')

    filename = "Visit_Report.docx"
    doc.save(filename)

    await update.message.reply_document(
        document=InputFile(filename)
    )

app = Application.builder().token(TOKEN).build()

app.add_handler(CommandHandler("start", start))
app.add_handler(Command
